class Solution {
    public int countPrimes(int n) {

        // SIEVE METHOD
        if(n <= 2){
            return 0;
        }

        boolean arr[] = new boolean[n];
        Arrays.fill(arr, true);

        arr[0] = false;
        arr[1] = false;

        for(int i=2; i*i<n; i++){ //SQRT(N) KE BAAD VALE NUMBERS PEHLE WALO KE HI MULTIPLES HONGE
            if(arr[i]){
                for(int j=i*i; j<n; j+=i){ //SQUARE KE BAAD SE TABLE CHALEGA, USSE PEHLE WALE MULTIPLES HOGYE BY <I WALE NUMBERS
                    arr[j] = false;
                }
            }
        }

        int ctr = 0;
        for(boolean b : arr){
            if(b){
                ctr++;
            }
        }
        return ctr;
    }
}
