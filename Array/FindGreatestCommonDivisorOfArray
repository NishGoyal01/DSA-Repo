class Solution {
    public int findGCD(int[] nums) {
        int min = Integer.MAX_VALUE;
        int max = Integer.MIN_VALUE;
        for(int i=0; i<nums.length; i++){
            min = Math.min(min, nums[i]);
            max = Math.max(max, nums[i]);
        }

        int dividend = max;
        int divisor = min;
        int r = dividend % divisor;
        while(r!=0){
            dividend = divisor;
            divisor = r;
            r = dividend % divisor;
        }
        return divisor;
    }
}
