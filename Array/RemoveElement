class Solution {
    public int removeElement(int[] nums, int val) {
        int n = nums.length;
        int l = 0;
        int r = n-1;
        int ctr = 0;
        while(l<=r){
            while(r>=0 && nums[r]==val){
                ctr++;
                r--;
            }
            if(nums[l]==val && r>l){
                ctr++;
                nums[l] = nums[r];
                r--;
            }
            l++;
        }
        return n-ctr;
    }
}
