class Solution {
    public String longestCommonPrefix(String[] strs) {
        String s = strs[0];
        for(int i=1; i<strs.length; i++){
            int j = 0;
            while(j<strs[i].length() && j<s.length()){
                if(strs[i].charAt(j) != s.charAt(j)){
                    break;
                }
                j++;
            }
            s = s.substring(0,j);
            if(s.length() == 0){
                break;
            }
        }
        return s;
    }
}
