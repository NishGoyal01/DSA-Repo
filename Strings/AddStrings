class Solution {
    public String addStrings(String num1, String num2) {
        int carry = 0;
        int i = num1.length() - 1;
        int j = num2.length() - 1;

        StringBuilder res = new StringBuilder();

        while (i >= 0 || j >= 0 || carry == 1) {
            int sum = 0;

            if (i >= 0) sum += num1.charAt(i--) - '0';
            if (j >= 0) sum += num2.charAt(j--) - '0';

            sum += carry;
            carry = sum / 10;

            res.append(sum % 10);
        }

        return res.reverse().toString();
    }
}
